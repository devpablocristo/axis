COMPOSE_PROJECT_NAME=axis

AXIS_CONSOLE_PORT=13000
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_JWT_TEMPLATE=axis-bff
AXIS_BFF_PORT=18080
AXIS_CONTROL_POSTGRES_PORT=15436
AXIS_CONTROL_DATABASE_URL=postgres://postgres:postgres@localhost:15436/axis_control?sslmode=disable
AXIS_INTERNAL_JWT_SECRET=axis-dev-internal-jwt-secret-change-me
AXIS_INTERNAL_JWT_ISSUER=axis-bff
AXIS_AUTH_ISSUER_URL=
AXIS_AUTH_AUDIENCE=axis-bff
AXIS_IDENTITY_PROVIDER=
AXIS_CLERK_SECRET_KEY=
AXIS_CLERK_API_BASE_URL=https://api.clerk.com/v1
AXIS_CLERK_WEBHOOK_SECRET=
AXIS_COMPANION_AUDIENCE=companion
AXIS_NEXUS_AUDIENCE=nexus
AXIS_ALLOWED_ORIGIN=
AXIS_DOWNSTREAM_TIMEOUT=10s
AXIS_READ_HEADER_TIMEOUT=5s
AXIS_OWNER_ORG=cristo.tech
AXIS_DEV_ORG_ID=axis
AXIS_OTHER_ORG_ID=other-dev-org
AXIS_DEV_USER_ID=local-dev-admin
AXIS_BOOTSTRAP_DEV_WORKSPACE=true
AXIS_DEV_PRODUCT_SURFACES=axis medmory
AXIS_DEV_SCOPES=

COMPANION_PORT=18085
COMPANION_POSTGRES_PORT=15435
COMPANION_ADMIN_API_KEY=companion-admin-dev-key
MEDMORY_AXIS_API_KEY=local-dev-medmory-axis-api-key
COMPANION_INTERNAL_API_KEY=local-internal-token
COMPANION_DATABASE_URL=postgres://postgres:postgres@localhost:15435/companion?sslmode=disable
COMPANION_AUTH_ISSUER_URL=
COMPANION_AUTH_AUDIENCE=
COMPANION_INTERNAL_JWT_AUDIENCE=companion
COMPANION_NEXUS_SYNC_INTERVAL_SEC=30
COMPANION_STRICT_NEXUS=false
COMPANION_DEFAULT_AUTONOMY_LEVEL=A2
COMPANION_WATCHER_INTERVAL_SEC=0
COMPANION_WATCHER_SYNC_INTERVAL_SEC=0
COMPANION_LLM_PROVIDER=vertex
COMPANION_LLM_MODEL=gemini-2.5-flash-lite
COMPANION_LLM_VERTEX_PROJECT=
COMPANION_LLM_VERTEX_LOCATION=
COMPANION_EMBEDDING_PROVIDER=
COMPANION_EMBEDDING_MODEL=
COMPANION_EMBEDDING_VERTEX_PROJECT=
COMPANION_EMBEDDING_VERTEX_LOCATION=
COMPANION_EMBEDDING_DIMENSIONS=64
COMPANION_OPS_ALERT_WEBHOOK_URL=
# JWTs HS256 per-producto hacia Companion. Formato:
# product=<secret>|issuer=<issuer>[;product2=...]
COMPANION_PRODUCT_JWT_KEYS="ponti=local-dev-ponti-jwt-secret|issuer=ponti-core"

NEXUS_PORT=18084
NEXUS_POSTGRES_PORT=15434
NEXUS_ADMIN_API_KEY=nexus-admin-dev-key
NEXUS_ADMIN_A_API_KEY=nexus-admin-a-dev-key
NEXUS_ADMIN_B_API_KEY=nexus-admin-b-dev-key
NEXUS_OTHER_ORG_ADMIN_API_KEY=nexus-admin-other-dev-key
NEXUS_PROMETHEUS_API_KEY=nexus-prometheus-dev-key
NEXUS_PONTI_API_KEY=nexus-ponti-dev-key
NEXUS_BASE_URL=http://localhost:18084
NEXUS_API_KEY=nexus-admin-dev-key
NEXUS_DATABASE_URL=postgres://postgres:postgres@localhost:15434/nexus?sslmode=disable
NEXUS_AUTH_ISSUER_URL=
NEXUS_AUTH_AUDIENCE=
NEXUS_INTERNAL_JWT_AUDIENCE=nexus
# JWTs HS256 per-producto hacia Nexus (mismo secret/issuer que Companion).
NEXUS_PRODUCT_JWT_KEYS="ponti=local-dev-ponti-jwt-secret|issuer=ponti-core"
NEXUS_ENV=local
NEXUS_APPROVAL_TTL=3600
NEXUS_SIGNING_KEY=nexus-dev-signing-key-change-in-production
# Token HMAC compartido con los productos que reciben callbacks (debe
# coincidir con NEXUS_CALLBACK_TOKEN en ponti/core).
NEXUS_CALLBACK_TOKEN=local-dev-callback-token
# Callbacks de approvals hacia productos. En dev se broadcastea a todas las
# URLs (sin ruteo por prefijo de action_type, decisión pendiente).
NEXUS_APPROVAL_PENDING_CALLBACK_URLS=http://host.docker.internal:8080/api/v1/governance/callbacks/nexus
NEXUS_APPROVAL_RESOLVED_CALLBACK_URLS=http://host.docker.internal:8080/api/v1/governance/callbacks/nexus
NEXUS_ATTESTATION_VERIFIER=none
NEXUS_ATTESTATION_HMAC_SECRET=
