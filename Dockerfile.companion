FROM golang:1.26-alpine AS builder

WORKDIR /src/companion

COPY companion/go.mod companion/go.sum ./
RUN go mod download

COPY companion/ ./

RUN CGO_ENABLED=0 go build -o /out/companion ./cmd/api

FROM alpine:3.23
RUN apk add --no-cache ca-certificates wget
WORKDIR /app
COPY --from=builder /out/companion /usr/local/bin/companion
COPY --from=builder /src/companion/scripts/evals ./scripts/evals
EXPOSE 8080
CMD ["companion"]
