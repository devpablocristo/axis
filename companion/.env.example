COMPOSE_PROJECT_NAME=companion

# Puertos (host)
COMPANION_PORT=18085
COMPANION_POSTGRES_PORT=15435

# API keys del propio servicio companion
COMPANION_ADMIN_API_KEY=companion-admin-dev-key
COMPANION_INTERNAL_API_KEY=local-internal-token

# Auth opcional para gateways/servicios internos (OIDC/JWKS)
COMPANION_AUTH_ISSUER_URL=
COMPANION_AUTH_AUDIENCE=
COMPANION_INTERNAL_JWT_SECRET=axis-dev-internal-jwt-secret-change-me
COMPANION_INTERNAL_JWT_ISSUER=axis-bff
COMPANION_INTERNAL_JWT_AUDIENCE=companion

# Dependencia server-side: Nexus Governance (proyecto separado).
# Solo Companion consume esta URL server-side.
# Puerto default 18084; ajustar si nexus/.env cambia GOVERNANCE_PORT.
GOVERNANCE_BASE_URL=http://host.docker.internal:18084
# Mismo valor que GOVERNANCE_ADMIN_API_KEY en nexus/.env (dev: governance-admin-dev-key).
GOVERNANCE_API_KEY=governance-admin-dev-key
COMPANION_GOVERNANCE_SYNC_INTERVAL_SEC=30
COMPANION_STRICT_GOVERNANCE=false

# Pymes Core (watchers proactivos)
PYMES_BASE_URL=
PYMES_API_KEY=

# Ponti (capabilities manifest dinámico)
PONTI_BASE_URL=
PONTI_API_KEY=

# Org dev usada por el API key admin del docker-compose. Evita operar con
# tenant vacío durante desarrollo.
COMPANION_DEV_ORG_ID=local-dev-org
COMPANION_WATCHER_INTERVAL_SEC=0
COMPANION_WATCHER_SYNC_INTERVAL_SEC=0

# LLM local igual que GCP: Vertex AI + Gemini via ADC de gcloud.
# Requiere `gcloud auth application-default login` en el host.
COMPANION_LLM_PROVIDER=vertex
COMPANION_LLM_MODEL=gemini-2.5-flash-lite
COMPANION_LLM_VERTEX_PROJECT=pymes-dev-352318
COMPANION_LLM_VERTEX_LOCATION=us-central1
