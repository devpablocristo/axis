        "max_attempts": 1
      },
      "preconditions": ["patient_context", "active_product_installation"],
      "postconditions": [],
      "observability_tags": ["product:medmory", "capability:read", "data:clinical"]
    },
    {
      "schema_version": "capability_manifest.v1",
      "capability_id": "medmory.share_link.create",
      "version": "1.0.0",
      "display_name": "Medmory share link create",
      "description": "Create a governed Medmory share link.",
      "owner": "medmory",
      "product_surface": "medmory",
      "connector": "medmory",
      "action_type": "write",
      "risk_level": "high",
      "side_effect_type": "write",
      "auth_mode": "api_key_ref",
      "required_scopes": ["medmory:share:write"],
      "input_schema": {
        "type": "object",
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "share_link_id": {"type": "string"},
          "status": {"type": "string"}
        },
        "additionalProperties": true
      },
      "evidence_schema": {
        "type": "object",
        "properties": {
          "source_ref": {"type": "string"},
          "captured_at": {"type": "string"},
          "tenant_scope": {"type": "string"},
