  },
  "capabilities": [
    {
      "schema_version": "capability_manifest.v1",
      "capability_id": "medmory.summary.read",
      "version": "1.0.0",
      "display_name": "Medmory clinical summary",
      "description": "Read a redacted clinical memory summary.",
      "owner": "medmory",
      "product_surface": "medmory",
      "connector": "medmory",
      "action_type": "read",
      "risk_level": "medium",
      "side_effect_type": "read",
      "auth_mode": "api_key_ref",
      "required_scopes": ["medmory:memory:read"],
      "input_schema": {
        "type": "object",
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "profile": {"type": "object"},
          "conditions": {
            "type": "array",
