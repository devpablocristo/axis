  "expected_errors": [
    {
      "scenario": "installation_missing",
      "expected_code": "FORBIDDEN"
    },
    {
      "scenario": "product_disabled",
      "expected_code": "FORBIDDEN"
    },
    {
      "scenario": "scope_missing",
      "expected_code": "FORBIDDEN"
    },
    {
      "scenario": "write_without_nexus",
