FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src/nexus

COPY nexus/go.mod nexus/go.sum ./
RUN go mod download

COPY nexus/ ./

RUN CGO_ENABLED=0 go build -o /out/nexus ./cmd/api

FROM alpine:3.24
RUN apk add --no-cache ca-certificates wget
COPY --from=builder /out/nexus /usr/local/bin/nexus
EXPOSE 8080
CMD ["nexus"]
