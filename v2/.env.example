# Executor for approved actions: disabled | local | google_calendar.
# google_calendar creates REAL events via the Google Calendar API using
# Application Default Credentials (mount gcloud ADC + set the calendar scope);
# it targets COMPANION_V2_GOOGLE_CALENDAR_ID (single calendar for all tenants
# in this first cut — do not use in a shared multi-tenant deployment).
COMPANION_V2_EXECUTION_MODE=local
