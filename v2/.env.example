BFF_V2_PORT=19080
BFF_V2_POSTGRES_PORT=19438
BFF_V2_POSTGRES_DB=bff_v2
BFF_V2_POSTGRES_USER=postgres
BFF_V2_POSTGRES_PASSWORD=postgres
BFF_V2_ENV=development
BFF_V2_RUN_MIGRATIONS=true
BFF_V2_MAX_BODY_BYTES=1048576
# Only POST /api/knowledge-bases/:id/ingestions/upload receives this larger envelope.
BFF_V2_KNOWLEDGE_UPLOAD_MAX_BODY_BYTES=263192576
BFF_V2_CORS_ORIGINS=http://localhost:19173,http://127.0.0.1:19173,http://console-v2:19173,http://console-v2-e2e:19173
BFF_V2_COMPANION_BASE_URL=http://companion-v2:8080
BFF_V2_NEXUS_BASE_URL=http://nexus-v2:8080
BFF_V2_DEV_ACTOR_ID=dev-user
BFF_V2_DEV_ACTOR_EMAIL=dev@example.local
BFF_V2_DEV_ORG_ID=dev-org
BFF_V2_IDENTITY_PROVIDER=dev
# Product machine credentials for the inbound edge (POST /v1/assist-runs).
# <apiKey>=<tenant>|<virployee>|<actor>|<product>  (comma/newline-separated entries)
# tenant|legacy_fallback_virployee|actor|product_surface|routing_pool(optional)
# BFF_V2_PRODUCT_API_KEYS=medmory-local-key=8c3a623a-f9d2-44d2-a71e-e9c14992031e|3e5a24e1-cfe2-44c9-8c15-698de5dade5a|service:medmory|medmory|POOL_UUID
AXIS_V2_INTERNAL_AUTH_SECRET=axis-v2-local-internal
BFF_V2_CLERK_SECRET_KEY=
BFF_V2_CLERK_API_BASE_URL=https://api.clerk.com/v1
BFF_V2_CLERK_ISSUER_URL=
BFF_V2_CLERK_WEBHOOK_SECRET=
BFF_V2_CLERK_INVITE_REDIRECT_URL=

AXIS_CONSOLE_PORT=19173
AXIS_CONSOLE_BFF_BASE_URL=http://bff-v2:8080
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_JWT_TEMPLATE=axis-bff

COMPANION_V2_PORT=19086
COMPANION_V2_POSTGRES_PORT=19437
COMPANION_V2_POSTGRES_DB=companion_v2
COMPANION_V2_POSTGRES_USER=postgres
COMPANION_V2_POSTGRES_PASSWORD=postgres
COMPANION_V2_ENV=development
COMPANION_V2_RUN_MIGRATIONS=true
COMPANION_V2_MAX_BODY_BYTES=1048576
# Multipart envelope: the file itself remains capped at 250 MiB.
COMPANION_V2_KNOWLEDGE_UPLOAD_MAX_BODY_BYTES=263192576
COMPANION_V2_WATCHER_INTERVAL_SEC=30
COMPANION_V2_STALE_ASSIST_SEC=300
COMPANION_V2_STALE_EXECUTION_SEC=300
COMPANION_V2_WATCHER_LEASE_SEC=30
COMPANION_V2_REPORT_BACKOFF_SEC=5
COMPANION_V2_WATCHER_BATCH_SIZE=50
COMPANION_V2_RECOVERY_MAX_ATTEMPTS=3
COMPANION_V2_REPORT_MAX_ATTEMPTS=3
COMPANION_V2_CORS_ORIGINS=http://localhost:19173,http://127.0.0.1:19173,http://console-v2:19173,http://console-v2-e2e:19173
COMPANION_V2_NEXUS_BASE_URL=http://nexus-v2:8080
COMPANION_V2_RUNTIME_BASE_URL=http://runtime-v2:8080
# Development-only bounded persistent staging. Production ignores this adapter
# and requires ARTIFACT_STAGING_BUCKET + CMEK + the malware scanner.
COMPANION_V2_ARTIFACT_LOCAL_STAGING_DIR=/var/lib/axis/artifacts
COMPANION_V2_ARTIFACT_LOCAL_MAX_BYTES=5368709120
COMPANION_V2_EXECUTION_MODE=local
# F6 real Google Calendar executor (see docs/f6-google-calendar-runbook.md).
# Set EXECUTION_MODE to google_calendar (or local,google_calendar), the target
# calendar id, and mount the service-account key via docker-compose.override.yml.
# COMPANION_V2_EXECUTION_MODE=google_calendar
# COMPANION_V2_GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcal-sa.json

RUNTIME_V2_PORT=19088
RUNTIME_V2_EMBEDDING_DIMENSIONS=768
# Deterministic local retrieval fallback; it is never selected in production.
RUNTIME_V2_DEVELOPMENT_EMBEDDINGS_ENABLED=true

NEXUS_V2_PORT=19087
NEXUS_V2_POSTGRES_PORT=19439
NEXUS_V2_POSTGRES_DB=nexus_v2
NEXUS_V2_POSTGRES_USER=postgres
NEXUS_V2_POSTGRES_PASSWORD=postgres
NEXUS_V2_ENV=development
NEXUS_V2_RUN_MIGRATIONS=true
NEXUS_V2_APPROVAL_TTL_SEC=3600
NEXUS_V2_WATCHER_INTERVAL_SEC=30
NEXUS_V2_WATCHER_BATCH_SIZE=100
NEXUS_V2_CORS_ORIGINS=http://localhost:19173,http://127.0.0.1:19173,http://console-v2:19173,http://console-v2-e2e:19173
