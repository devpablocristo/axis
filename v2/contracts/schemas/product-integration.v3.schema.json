{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axis.local/contracts/schemas/product-integration.v3.schema.json",
  "title": "axis.product-integration.v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authentication",
    "limits",
    "entrypoints",
    "capabilities",
    "events",
    "governed_operations",
    "connector_bindings"
  ],
  "properties": {
    "schema_version": {
      "const": "axis.product-integration.v3"
    },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "scopes"
      ],
      "properties": {
        "mode": {
          "const": "api_key"
        },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/code"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_request_bytes",
        "max_result_bytes",
        "rate_per_minute"
      ],
      "properties": {
        "max_request_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 268435456
        },
        "max_result_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 268435456
        },
        "rate_per_minute": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000
        }
      }
    },
    "entrypoints": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "id"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "virployee",
              "routing_pool"
            ]
          },
          "id": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "events": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "governed_operations": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "$ref": "#/$defs/governedOperation"
      }
    },
    "connector_bindings": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "$ref": "#/$defs/connectorBinding"
      }
    }
  },
  "$defs": {
    "code": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "manifest_hash",
        "executor_binding_id",
        "operation",
        "input_schema_hash",
        "output_schema_hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "manifest_hash": {
          "$ref": "#/$defs/sha256"
        },
        "executor_binding_id": {
          "$ref": "#/$defs/code"
        },
        "operation": {
          "$ref": "#/$defs/code"
        },
        "input_schema_hash": {
          "$ref": "#/$defs/sha256"
        },
        "output_schema_hash": {
          "$ref": "#/$defs/sha256"
        },
        "legacy_key": {
          "$ref": "#/$defs/code"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "version",
        "schema",
        "schema_hash"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/code"
        },
        "version": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "schema": {
          "type": "object"
        },
        "schema_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "governedOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "operation",
        "required_scopes"
      ],
      "properties": {
        "capability_id": {
          "type": "string",
          "format": "uuid"
        },
        "operation": {
          "$ref": "#/$defs/code"
        },
        "required_scopes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/code"
          }
        }
      }
    },
    "connectorBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "connector_id",
        "operation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/code"
        },
        "connector_id": {
          "$ref": "#/$defs/code"
        },
        "operation": {
          "$ref": "#/$defs/code"
        },
        "secret_ref": {
          "type": "string",
          "pattern": "^secret://[^\\s]{1,502}$"
        }
      }
    }
  }
}
