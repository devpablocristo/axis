{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axis.local/contracts/schemas/connector.v1.schema.json",
  "title": "axis.connector.v1 descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "base_url",
    "product_id",
    "secret_ref",
    "operations"
  ],
  "properties": {
    "schema_version": {
      "const": "axis.connector.v1"
    },
    "binding_id": {
      "$ref": "#/$defs/code"
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "product_id": {
      "type": "string",
      "format": "uuid"
    },
    "secret_ref": {
      "type": "string",
      "pattern": "^(secretmanager://[^\\s]{1,488}|env://[A-Z][A-Z0-9_]{0,127})$"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": {
        "$ref": "#/$defs/operation"
      }
    }
  },
  "$defs": {
    "code": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$"
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "capability_id",
        "input_schema",
        "output_schema",
        "max_request_bytes",
        "max_response_bytes",
        "timeout_ms"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/code"
        },
        "capability_id": {
          "type": "string",
          "format": "uuid"
        },
        "input_schema": {
          "type": "object"
        },
        "output_schema": {
          "type": "object"
        },
        "max_request_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "max_response_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4194304
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 300000
        }
      }
    }
  }
}
