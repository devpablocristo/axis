FROM golang:1.26-alpine AS build

WORKDIR /src/bff

COPY bff/go.mod bff/go.sum ./
RUN go mod download

COPY bff/ ./
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/axis-bff .

FROM alpine:3.23
RUN adduser -D -H axis
USER axis
COPY --from=build /out/axis-bff /axis-bff
EXPOSE 8080
ENTRYPOINT ["/axis-bff"]
